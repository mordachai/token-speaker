<form class="ts-simple-config standard-form" autocomplete="off">

  <fieldset>
    <legend>Bounce</legend>
    <div class="form-group slim">
      <label>Max Y offset (px)</label>
      <div class="form-fields">
        <input type="range" name="bounceMax" min="0" max="50" step="1" value="{{bounceMax}}">
        <span class="range-value">{{bounceMax}}</span>
      </div>
      <p class="hint">Upward amplitude in pixels while speaking. 0 disables bounce.</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>Wobble</legend>
    <div class="form-group slim">
      <label>Max rotation (°)</label>
      <div class="form-fields">
        <input type="range" name="angleMax" min="0" max="30" step="1" value="{{angleMax}}">
        <span class="range-value">{{angleMax}}</span>
      </div>
      <p class="hint">Maximum rotation at full intensity. 0 disables wobble.</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>Scale</legend>
    <div class="form-group slim">
      <label>Axis</label>
      <div class="form-fields">
        <select name="scaleAxis">
          {{#each scaleAxisOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <div class="form-group slim">
      <label>Low limit</label>
      <div class="form-fields">
        <input type="range" name="scaleLow" min="0.5" max="1.0" step="0.05" value="{{scaleLow}}">
        <span class="range-value">{{scaleLow}}</span>
      </div>
      <p class="hint">Minimum scale the animation vibrates down to. 1.0 = no squish.</p>
    </div>
    <div class="form-group slim">
      <label>High limit</label>
      <div class="form-fields">
        <input type="range" name="scaleHigh" min="1.0" max="2.0" step="0.05" value="{{scaleHigh}}">
        <span class="range-value">{{scaleHigh}}</span>
      </div>
      <p class="hint">Maximum scale the animation vibrates up to.</p>
    </div>
    <div class="form-group slim">
      <label>Damping</label>
      <div class="form-fields">
        <input type="range" name="scaleDamping" min="0" max="0.95" step="0.05" value="{{scaleDamping}}">
        <span class="range-value">{{scaleDamping}}</span>
      </div>
      <p class="hint">0 = raw waveform (max tremors). Higher = smoother, fewer tremors.</p>
    </div>
  </fieldset>

  <footer class="sheet-footer flexrow">
    <button type="button" data-action="save">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>

</form>
