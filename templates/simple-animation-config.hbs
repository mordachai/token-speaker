<form class="ts-simple-config standard-form {{#if debug}}ts-debug-on{{/if}} {{#if showBounce}}ts-bounce-on{{/if}}" autocomplete="off">

  <fieldset>
    <legend>Speaking Indicator</legend>
    <div class="form-group slim">
      <label>Style</label>
      <div class="form-fields">
        <select name="indicatorStyle">
          {{#each indicatorOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">Ring: coloured circle around the token. Bubble: animated speech bubble above it. Independent from the Talking Head indicator.</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>Animation Mode</legend>
    <div class="form-group slim">
      <label>Mode</label>
      <div class="form-fields">
        <select name="mode">
          {{#each modeOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">None: no animation. Simple: bounce/wobble. Advanced: viseme lip-sync. Hybrid: visemes when sprites found, bounce otherwise.</p>
    </div>
  </fieldset>

  <fieldset class="ts-bounce-config">
    <legend>Bounce Config</legend>
    <div class="form-group slim">
      <label>Preset</label>
      <div class="form-fields">
        <select name="bouncePreset">
          {{#each presetOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">Choose a bounce style. Used when Debug mode is off. Tune preset values in scripts/animation-presets.mjs.</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>Debug</legend>
    <div class="form-group slim">
      <label>Debug Mode</label>
      <div class="form-fields">
        <input type="checkbox" name="debugMode" {{#if debug}}checked{{/if}}>
      </div>
      <p class="hint">Reveal all raw sliders to test freely. When on, slider values override the selected preset.</p>
    </div>
  </fieldset>

  <fieldset class="ts-debug-only">
    <legend>Intensity</legend>
    <div class="form-group slim">
      <label>Intensity</label>
      <div class="form-fields">
        <input type="range" name="intensity" min="0.1" max="3.0" step="0.1" value="{{intensity}}">
        <span class="range-value">{{intensity}}</span>
      </div>
      <p class="hint">Gain on mic volume for animation. Higher = easier to reach limits.</p>
    </div>
  </fieldset>

  <fieldset class="ts-debug-only">
    <legend>Bounce</legend>
    <div class="form-group slim">
      <label>Max Y offset (px)</label>
      <div class="form-fields">
        <input type="range" name="bounceMax" min="0" max="50" step="1" value="{{bounceMax}}">
        <span class="range-value">{{bounceMax}}</span>
      </div>
      <p class="hint">Upward amplitude in pixels while speaking. 0 disables bounce.</p>
    </div>
  </fieldset>

  <fieldset class="ts-debug-only">
    <legend>Wobble</legend>
    <div class="form-group slim">
      <label>Max rotation (°)</label>
      <div class="form-fields">
        <input type="range" name="angleMax" min="0" max="30" step="1" value="{{angleMax}}">
        <span class="range-value">{{angleMax}}</span>
      </div>
      <p class="hint">Maximum rotation at full intensity. 0 disables wobble.</p>
    </div>
  </fieldset>

  <fieldset class="ts-debug-only">
    <legend>Scale</legend>
    <div class="form-group slim">
      <label>Axis</label>
      <div class="form-fields">
        <select name="scaleAxis">
          {{#each scaleAxisOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <div class="form-group slim">
      <label>Low limit</label>
      <div class="form-fields">
        <input type="range" name="scaleLow" min="0.5" max="1.0" step="0.05" value="{{scaleLow}}">
        <span class="range-value">{{scaleLow}}</span>
      </div>
      <p class="hint">Minimum scale the animation vibrates down to. 1.0 = no squish.</p>
    </div>
    <div class="form-group slim">
      <label>High limit</label>
      <div class="form-fields">
        <input type="range" name="scaleHigh" min="1.0" max="2.0" step="0.05" value="{{scaleHigh}}">
        <span class="range-value">{{scaleHigh}}</span>
      </div>
      <p class="hint">Maximum scale the animation vibrates up to.</p>
    </div>
    <div class="form-group slim">
      <label>Damping</label>
      <div class="form-fields">
        <input type="range" name="scaleDamping" min="0" max="0.95" step="0.05" value="{{scaleDamping}}">
        <span class="range-value">{{scaleDamping}}</span>
      </div>
      <p class="hint">0 = raw waveform (max tremors). Higher = smoother, fewer tremors.</p>
    </div>
  </fieldset>

  <footer class="sheet-footer flexrow">
    <button type="button" data-action="save">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>

</form>
